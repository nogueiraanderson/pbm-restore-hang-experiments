@@ -251,12 +251,23 @@ func (r *PhysRestore) close(noerr bool, progress nodeStatus) (err error) {
 		}
 	}

+	// Stop restore heartbeats BEFORE waiting for cluster status. The
+	// heartbeat goroutine otherwise keeps refreshing cluster.hb, which
+	// prevents the staleness check in waitClusterStatus() from ever
+	// firing; if another node's status file is missing, the agent
+	// loops forever uploading heartbeats.
+	if r.stopHB != nil {
+		close(r.stopHB)
+	}
+
 	r.log.Debug("wait for cluster status")
 	cStatus, err := r.waitClusterStatus()
 	if err != nil {
 		r.log.Warning("waiting for cluster status during cleanup: %v", err)
 	}

+	// Create new channel for cleanup heartbeats (separate from restore HBs)
+	r.stopHB = make(chan struct{})
 	go r.startCleanupHb()

